rules_version = '2';

// ============================================================
// Storage Security Rules — Plane Aviation
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {

    // 1. Checa o nível de permissão do usuário no Firestore
    function role() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data.role;
    }
    
    // 2. Garante que está logado e é admin ou editor
    function isEditor() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (role() == 'admin' || role() == 'editor');
    }
    
    // 3. Garante que é uma imagem de no máximo 8MB
    function validImage() {
      return request.resource.size < 8 * 1024 * 1024 
        && request.resource.contentType.matches('image/.*'); 
    }

    // Aplica a regra para TODAS as pastas (Aeronaves, Artigos, Parceiros, etc)
    match /{allPaths=**} {
      // Leitura pública (o site mostra as fotos para todos)
      allow read: if true;
      
      // Criar e Atualizar: Exige ser admin e que o arquivo seja uma imagem válida
      allow create, update: if isEditor() && validImage();
      
      // Deletar: Exige apenas ser admin (não checa o tamanho, senão trava)
      allow delete: if isEditor();
    }
  }
}