rules_version = '2';

// ============================================================
// Firestore Security Rules — Plane Aviation
// Toda a AUTORIZAÇÃO REAL mora aqui (não na interface).
// Publicar em: Firebase Console → Firestore → Regras.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasRoleDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return hasRoleDoc() && userDoc().role == 'admin';
    }
    function isEditor() {
      return hasRoleDoc() && (userDoc().role == 'admin' || userDoc().role == 'editor');
    }

    // Aeronaves à venda
    match /aircraft/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Frota de demonstração (Universo Cirrus)
    match /cirrusFleet/{id} {
      allow read: if true;
      allow write: if isEditor();
    }
    
    // Rede de Parceiros
    match /partners/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Configurações do site
    match /siteConfig/{id} {
      allow read: if true;
      allow write: if isEditor();
    }
    
    // Inscrições da Newsletter
    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isEditor();
    }

		// Artigos e Podcasts (News & Insights)
    match /articles/{id} {
      allow read: if true;
      allow write: if isEditor();
    }
    match /podcasts/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /videos/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Usuários / papéis
    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // NOVO: Leads (Mensagens do Contato)
    // Público pode criar. Apenas equipe interna pode ler, editar ou excluir.
    match /leads/{id} {
      allow create: if true;
      allow read, update, delete: if isEditor();
    }

    // Bloqueia qualquer outra coleção
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}